# LOG
CIBUILD_LOG_LEVEL=3

# TARGET
CIBUILD_TARGET_REGISTRY=docker.io
CIBUILD_TARGET_REGISTRY_USER=stack4ops
CIBUILD_TARGET_IMAGE_PATH=stack4ops/cibuilder
CIBUILD_TARGET_TAG=rootless

# CHECK
CIBUILD_CHECK_ENABLED=1

# BUILD
CIBUILD_BUILD_FORCE=0
CIBUILD_BUILD_NATIVE=1

# TEST
CIBUILD_TEST_ENABLED=1
CIBUILD_TEST_BACKEND=docker
CIBUILD_TEST_RUN_TIMEOUT=120
DOCKER_HOST=tcp://docker:2375

# DEPLOY
CIBUILD_DEPLOY_ADDITIONAL_TAGS=__DATETIME__
CIBUILD_DEPLOY_MINOR_TAG_REGEX='^v0\.(2|3|4|5|6|7|8|9)\d+\.\d+-rootless$'