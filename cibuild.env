# LOG
CIBUILD_LOG_LEVEL=3

# CHECK
CIBUILD_CHECK_ENABLED=1

# BUILD
CIBUILD_BUILD_FORCE=1
CIBUILD_BUILD_NATIVE=1
CIBUILD_BUILD_TAG=rootless
CIBUILD_BUILD_SBOM=1
CIBUILD_BUILD_PROVENANCE=1

# TEST
CIBUILD_TEST_ENABLED=1
CIBUILD_TEST_BACKEND=docker
CIBUILD_TEST_RUN_TIMEOUT=120
DOCKER_HOST=tcp://docker:2375

# RELEASE
CIBUILD_RELEASE_IMAGE_TAGS=__DATETIME__,__MINORTAG__
CIBUILD_RELEASE_MINOR_TAG_REGEX='^v0\.(2|3|4|5|6|7|8|9)\d+\.\d+-rootless$'
CIBUILD_RELEASE_SIGNATURE=1
CIBUILD_RELEASE_VERIFY_SIGNATURES=1


