{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "configMigration": true,
  "pinDigests": true,
  "dockerfile": {
    "enabled": true
  },
  "nix": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "schedule": [
    "every weekend"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "debian base image — pin to 13-slim, digest updates only",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "debian"
      ],
      "versioning": "docker",
      "allowedVersions": "/^13-slim/",
      "automerge": false,
      "labels": [
        "dependencies",
        "base-image"
      ],
      "commitMessagePrefix": "fix(base):"
    },
    {
      "description": "docker CLI — manual review",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker"
      ],
      "versioning": "semver",
      "automerge": false,
      "labels": [
        "dependencies",
        "docker"
      ],
      "commitMessagePrefix": "chore(docker):"
    },
    {
      "description": "buildkit + rootlesskit — manual review (kernel-level impact)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "moby/buildkit",
        "rootless-containers/rootlesskit"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "buildkit"
      ],
      "commitMessagePrefix": "chore(buildkit):"
    },
    {
      "description": "kaniko — manual review",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "martizih/kaniko"
      ],
      "versioning": "semver",
      "automerge": false,
      "labels": [
        "dependencies",
        "kaniko"
      ],
      "commitMessagePrefix": "chore(kaniko):"
    },
    {
      "description": "binary tools (regctl, cosign, trivy) — manual review (supply chain sensitive)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "regclient/regclient",
        "sigstore/cosign",
        "aquasecurity/trivy"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "tools"
      ],
      "commitMessagePrefix": "chore(tools):"
    },
    {
      "description": "kubectl — manual review (k8s version skew policy)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "kubernetes/kubernetes"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "kubectl"
      ],
      "commitMessagePrefix": "chore(kubectl):"
    },
    {
      "description": "apt packages — manual review",
      "matchDatasources": [
        "deb"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "apt"
      ],
      "commitMessagePrefix": "chore(apt):"
    },
    {
      "description": "nix flake inputs — auto-merge",
      "matchManagers": [
        "nix"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": [
        "dependencies",
        "nix"
      ],
      "commitMessagePrefix": "chore(nix):"
    },
    {
      "description": "GitHub Actions — auto-merge",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": [
        "dependencies",
        "ci"
      ],
      "commitMessagePrefix": "chore(ci):"
    },
    {
      "description": "all docker images — always pin digests",
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    }
  ],
  "customManagers": [
    {
      "description": "regctl ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG REGCTL_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-releases depName=regclient/regclient"
      ],
      "depNameTemplate": "regclient/regclient",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "cosign ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG COSIGN_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-releases depName=sigstore/cosign"
      ],
      "depNameTemplate": "sigstore/cosign",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "trivy ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG TRIVY_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-releases depName=aquasecurity/trivy"
      ],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "buildkit ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG BUILDKIT_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-releases depName=moby/buildkit"
      ],
      "depNameTemplate": "moby/buildkit",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "rootlesskit ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG ROOTLESSKIT_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-releases depName=rootless-containers/rootlesskit"
      ],
      "depNameTemplate": "rootless-containers/rootlesskit",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "kubectl ARG version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG KUBECTL_VERSION=(?<currentValue>[\\d.]+)\\s+# renovate: datasource=github-tags depName=kubernetes/kubernetes"
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "apt packages — debian main repo",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG [A-Z0-9_]+=(?<currentValue>[^\\s]+)\\s+# renovate: suite=(?<suite>[a-z]+) depName=(?<depName>[a-zA-Z0-9.+_-]+)"
      ],
      "registryUrlTemplate": "https://deb.debian.org/debian?suite={{suite}}&components=main,contrib,non-free&binaryArch=amd64",
      "datasourceTemplate": "deb"
    },
    {
      "description": "apt packages — debian security repo (+debXuY patches)",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/"
      ],
      "matchStrings": [
        "ARG [A-Z0-9_]+=(?<currentValue>[^\\s]+)\\s+# renovate: suite=(?<suite>[a-z]+) depName=(?<depName>[a-zA-Z0-9.+_-]+)"
      ],
      "registryUrlTemplate": "https://deb.debian.org/debian-security?suite={{suite}}-security&components=main,contrib,non-free&binaryArch=amd64",
      "datasourceTemplate": "deb"
    }
  ],
  "labels": [
    "renovate"
  ]
}