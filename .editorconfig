# EditorConfig for consistent file formatting

root = true

# Unix-style newlines, UTF-8 encoding
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts
[*.sh]
indent_size = 2
max_line_length = 120

# Bats test files
[*.bats]
indent_size = 2

# Dockerfile
[Dockerfile]
indent_size = 2

# YAML files
[*.{yaml,yml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Configuration files
[*.{env,conf}]
indent_size = 2